{
    "$schema": "https://apidocs.iqrf.org/iqrf-gateway-daemon/com.iqrftech.self-desc/schema/jsonschema/1-0-0#",
    "self": {
        "vendor": "com.iqrftech.self-desc",
        "name": "schema__iqrf__WebsocketMessaging",
        "format": "jsonschema",
        "version": "1-0-0"
    },
    "type": "object",
    "required": [
        "component",
        "instance",
        "port",
        "acceptAsyncMsg",
        "acceptOnlyLocalhost",
        "transportMode",
        "tlsMode",
        "tlsPort",
        "cert",
        "privKey",
        "authTimeout",
        "maxClients"
    ],
    "additionalProperties": false,
    "properties": {
        "component": {
            "type": "string",
            "description": "Name of component.",
            "enum": [
                "iqrf::WebsocketMessaging"
            ]
        },
        "instance": {
            "type": "string",
            "description": "Recomended iqrf::WebsocketMessaging-(id)",
            "pattern": "^[^&]+$",
            "default": "iqrf::WebsocketMessaging-1"
        },
        "port":  {
            "type": "integer",
            "description": "Server port number",
            "default": 1338,
            "minimum": 1,
            "maximum": 65535
        },
        "acceptAsyncMsg": {
            "type": "boolean",
            "description": "Accept asynchronous messages"
        },
        "acceptOnlyLocalhost": {
            "type": "boolean",
            "description": "Only accept localhost connections"
        },
        "transportMode": {
            "type": "string",
            "description": "Transport mode",
            "enum": [
                "plain",
                "tls",
                "both"
            ]
        },
        "tlsMode": {
            "type": "string",
            "description": "TLS configuration",
            "enum": [
                "modern",
                "intermediate",
                "old"
            ]
        },
        "tlsPort":  {
            "type": "integer",
            "description": "Server TLS port number",
            "default": 8338,
            "minimum": 1,
            "maximum": 65535
        },
        "cert": {
            "type": "string",
            "description": "Certificate file"
        },
        "privKey": {
            "type": "string",
            "description": "Private key file"
        },
        "authTimeout": {
            "type": "integer",
            "description": "Authentication timeout for clients",
            "minimum": 10,
            "maximum": 60
        },
        "maxClients": {
            "type": "integer",
            "description": "Maximum number of connected clients",
            "minimum": 0,
            "default": 50
        }
    }
}
